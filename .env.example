# Serverless function endpoint for contact form submissions
VITE_CONTACT_FORM_ENDPOINT=/api/contact

# Contact form — recipient and sender addresses
CONTACT_EMAIL_TO=you@example.com
CONTACT_EMAIL_FROM=noreply@example.com

# SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
